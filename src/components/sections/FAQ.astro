---
const faqs = [
  {
    question: "Combien de temps faut-il pour construire un produit ?",
    answer:
      "Cela dépend de la portée et de la complexité. Un MVP typique prend 4 à 8 semaines, tandis que des projets plus complexes peuvent prendre 3 à 6 mois. Nous vous fournirons un calendrier détaillé après avoir compris vos besoins.",
  },
  {
    question: "Travaillez-vous avec des startups ou des entreprises ?",
    answer:
      "Nous travaillons avec les deux. Que vous soyez une startup cherchant à lancer un MVP rapidement ou une entreprise souhaitant moderniser ses outils internes, nous adaptons notre approche à votre contexte.",
  },
  {
    question: "Qu'est-ce qui est inclus dans vos services ?",
    answer:
      "Nos services couvrent l'ensemble du cycle : conception UX/UI, développement front-end et back-end, intégration d'API, déploiement cloud, et maintenance post-lancement. Tout sous un même toit.",
  },
  {
    question: "Pouvez-vous aider à l'intégration de l'IA ?",
    answer:
      "Oui, nous intégrons des solutions d'IA dans vos produits : chatbots, recommandations, traitement de données, ou intégration d'API comme OpenAI. Nous vous guidons du choix de la solution jusqu'au déploiement.",
  },
  {
    question: "Comment se déroule la collaboration au quotidien ?",
    answer:
      "Nous travaillons en sprints avec des points réguliers. Vous avez accès à un tableau de suivi en temps réel, et nos équipes restent disponibles via Slack ou email tout au long du projet.",
  },
];
---

<section id="faq" class="bg-[#F5F5F7] py-20 md:py-28">
  <div class="container mx-auto px-7 md:px-0">
    <!-- Header -->
    <div class="mx-auto mb-12 flex max-w-3xl flex-col gap-4 text-center">
      <p class="faq-anim text-xl text-black">05</p>
      <p
        class="faq-anim text-lg font-extralight tracking-[25%] text-black uppercase lg:text-xl"
      >
        [FAQ]
      </p>
      <h2
        class="faq-anim font-urbanist text-4xl leading-tight font-medium text-black lg:text-5xl"
      >
        Les questions fréquentes que nous recevons de nos clients.
      </h2>
    </div>

    <!-- Accordion -->
    <div class="mx-auto max-w-3xl">
      <Accordion variant="splitted" class="faq-accordion">
        {
          faqs.map((faq, i) => (
            <AccordionItem
              title={faq.question}
              name="faq"
              open={i === 0}
              class={`faq-item faq-anim ${i === 0 ? "faq-item--open" : ""}`}
            >
              <p class="faq-answer text-sm leading-relaxed md:text-base">
                {faq.answer}
              </p>
            </AccordionItem>
          ))
        }
      </Accordion>
    </div>

    <!-- Bottom CTA -->
    <div class="mx-auto mt-8 flex max-w-3xl flex-col items-center gap-4">
      <div
        class="faq-anim flex w-full items-center justify-between gap-4 rounded-full px-3 py-3"
        style="background: linear-gradient(to right, #5eead4, #a3e635);"
      >
        <div class="flex items-center gap-4">
          <div
            class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-white"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-6 w-6 fill-none stroke-black"
              stroke-width="2"
            >
              <path
                d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <span class="text-base font-semibold text-black md:text-lg"
            >Une autre question ?</span
          >
        </div>
        <a
          href="#contact"
          class="flex flex-shrink-0 items-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-black transition-colors hover:bg-black hover:text-white md:text-base"
        >
          Réserver un appel
          <svg viewBox="0 0 16 16" class="h-4 w-4" fill="none">
            <path
              d="M3 13L13 3M13 3H6M13 3v7"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
      <p class="text-sm text-gray-400">ou envoyez-nous un email à</p>
      <a
        href="mailto:contact@my-agency.io"
        class="flex items-center gap-2 text-sm font-medium text-black underline underline-offset-4"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5 fill-none stroke-black"
          stroke-width="2"
        >
          <rect
            x="2"
            y="4"
            width="20"
            height="16"
            rx="2"
            stroke-linecap="round"
            stroke-linejoin="round"></rect>
          <path
            d="M2 7l10 7 10-7"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        contact@my-agency.io
      </a>
    </div>
  </div>
</section>

<style>
  .faq-anim {
    opacity: 0;
  }

  /* Override accordion splitted spacing */
  .faq-accordion {
    gap: 0.75rem !important;
  }

  /* Item base : fond blanc, texte noir */
  .faq-item {
    background-color: #ffffff !important;
    border-color: transparent !important;
    box-shadow: none !important;
    border-radius: 1rem !important;
    transition: background-color 0.3s ease;
  }

  .faq-item .ac-accordion-item-title {
    color: #0a0a0a !important;
    padding: 1.25rem 1.5rem !important;
  }

  .faq-item .ac-accordion-item-title > svg {
    color: #ffffff !important;
    background-color: #0a0a0a;
    border-radius: 9999px;
    padding: 4px;
    width: 1.75rem !important;
    height: 1.75rem !important;
  }

  .faq-item .faq-answer {
    color: #4a4a4a;
    padding: 0 1.5rem 1.25rem;
  }

  /* Item ouvert : fond noir, texte blanc */
  .faq-item[open] {
    background-color: #0a0a0a !important;
  }

  .faq-item[open] .ac-accordion-item-title {
    color: #ffffff !important;
  }

  .faq-item[open] .ac-accordion-item-title > svg {
    color: #0a0a0a !important;
    background-color: rgba(255 255 255 / 0.2);
  }

  .faq-item[open] .faq-answer {
    color: rgba(255 255 255 / 0.75);
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initFaqAnimations() {
    const section = document.getElementById("faq");
    if (!section) return;

    gsap.fromTo(
      section.querySelectorAll(".faq-anim"),
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power3.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          toggleActions: "play none none none",
        },
      },
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFaqAnimations);
  } else {
    initFaqAnimations();
  }
</script>
