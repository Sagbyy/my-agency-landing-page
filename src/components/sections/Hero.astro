---
import Button from '../ui/Button.astro';
import headerVideo from '../../assets/hero/header-desktop.mp4';
import headerImage from '../../assets/hero/hero-card-bg.png';


---

<section class="relative min-h-screen h-screen overflow-hidden pb-24 pt-36">
  <video
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 w-full h-full object-cover"
    aria-hidden="true"
  >
    <source src={headerVideo} type="video/mp4" />
  </video>
  <div class="container mx-auto h-full">
    <div
      id="hero-card"
      class="relative z-10 flex flex-col gap-5 justify-center h-full p-16 text-white w-[550px] rounded-3xl"
      style={{ backgroundImage: `url(${headerImage.src})`, backgroundPosition: '30%', backgroundSize: 'cover', backgroundRepeat: 'no-repeat' }}
    >
      <p class="hero-anim uppercase text-xl font-light">Full-cycle product team</p>
      <h1 class="hero-anim text-5xl font-normal font-urbanist">We Design & Build Digital Products from Scratch.</h1>
      <p class="hero-anim">Got an idea for a product? We'll design it, build it, and launch it — all under one roof.</p>
      <div class="hero-anim">
        <Button href="/" text="Commencer votre projet" color="white" />
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initHeroAnimations() {
    const items = document.querySelectorAll('.hero-anim');
    if (!items.length) return;

    gsap.fromTo(
      items,
      { opacity: 0, y: 32 },
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.12,
        ease: 'power3.out',
        delay: 0.2,
      }
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroAnimations);
  } else {
    initHeroAnimations();
  }
</script>